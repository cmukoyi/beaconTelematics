# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://beacon_user:your-password-here@db:5432/beacon_telematics

# JWT Secret Key (generate a secure random string, min 32 chars)
SECRET_KEY=your-super-secret-jwt-key-min-32-chars-long

# SendGrid Email Configuration (Recommended for Production)
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=noreply@beacontelematics.co.uk

# MZone API Configuration
MZONE_API_URL=https://api.myprofiler.com/oauth2/v1
MZONE_REDIRECT_URI=http://your-server-ip/api/v1/mzone/callback
MZONE_CLIENT_ID=Tracking_GPS
MZONE_CLIENT_SECRET=your-mzone-client-secret-here
MZONE_VEHICLE_GROUP_ID=8e4fe3a7-4d46-474d-bf57-993828f70968
# Trips group ID — may differ from vehicle group ID (check MZone portal)
MZONE_TRIPS_GROUP_ID=e7042dff-f0d8-42ec-9324-c4b730cf177d

# TrackSolid Device Provider (optional — only needed if using TrackSolid GPS trackers)
TRACKSOLID_ACCOUNT=your-tracksolid-account
TRACKSOLID_PASSWORD=your-tracksolid-password
TRACKSOLID_USER_ID=your-user-id
TRACKSOLID_ORG_ID=your-org-id
TRACKSOLID_APP_KEY=your-app-key
TRACKSOLID_APP_SECRET=your-app-secret

# Optional Settings
DEBUG=False
